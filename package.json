{
  "name": "my-calendar",
  "version": "1.1.0",
  "description": "My Calendar - Electron Desktop App",
  "main": "main.js",
  "author": "Michael Mesa",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.mycalendar.app",
    "productName": "My Calendar",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "HTML/**/*",
      "CSS/**/*",
      "JS/**/*",
      "IMG/**/*",
      "DATA/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}